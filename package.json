{
  "name": "better-astraflow",
  "version": "0.1.0",
  "private": true,
  "productName": "Better AstraFlow",
  "description": "Better AstraFlow desktop client.",
  "main": "electron/main.cjs",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k -n next,electron -c cyan,magenta \"bun run dev\" \"wait-on http://localhost:3000 && ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:icon": "node scripts/generate-mac-icon.mjs",
    "electron:prepare": "node scripts/prepare-electron-next.mjs",
    "electron:pack": "bun run electron:icon && bun run build && bun run electron:prepare && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir",
    "electron:mac": "bun run electron:icon && bun run build && bun run electron:prepare && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac"
  },
  "build": {
    "appId": "cn.ucloud.astraflow.better",
    "productName": "Better AstraFlow",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.icns",
        "to": "icon.icns"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.0",
    "@ai-sdk/react": "^4.0.4",
    "@base-ui/react": "^1.6.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^7.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "gsap": "^3.15.0",
    "i18next": "^26.3.3",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.8",
    "react-jsx-parser": "^2.4.1",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.1",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "stream-markdown-parser": "^1.0.8",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
